# Docs (suitenumerique / impress) — the Phase 2 vertical slice (ADR-016).
# Wired to the Phase 1 foundation: CNPG (`docs` DB), Valkey (cache + Celery
# broker), S3 (RustFS in-cluster or external), and Keycloak SSO (client `docs`).
# Every credential comes from a seed-derived Secret via secretKeyRef (ADR-012);
# nothing secret is rendered here. Image tags are pinned in versions.yaml.
#
# OIDC uses an external/internal endpoint split: the browser hits Keycloak at
# https://auth.{domain}, while the backend reaches it in-cluster over plain HTTP
# (no TLS trust needed, works with the self-signed issuer in CI).

{{- $domain := .Values.domain -}}
{{- $host := printf "docs.%s" $domain -}}
{{- $realm := .Values.keycloak.realm -}}
{{- $ns := .Values.workloadsNamespace -}}
{{- $pgHost := printf "%s-rw.%s.svc.cluster.local" .Values.postgres.clusterName $ns -}}
{{- $kcExternal := printf "https://auth.%s/realms/%s/protocol/openid-connect" $domain $realm -}}
{{- $kcInternal := printf "http://keycloak-keycloakx-http.%s.svc.cluster.local/realms/%s/protocol/openid-connect" $ns $realm -}}
{{- $s3Endpoint := .Values.objectStorage.endpoint -}}
{{- $s3Region := .Values.objectStorage.region -}}
{{- if .Values.rustfs.enabled -}}
{{-   $s3Endpoint = printf "http://rustfs-svc.%s.svc.cluster.local:9000" $ns -}}
{{-   $s3Region = .Values.rustfs.region -}}
{{- end -}}
{{- $verifySsl := ternary "False" "True" (eq .Values.tls.issuer "selfsigned") -}}
{{- $mediaMiddlewares := printf "%s-docs-media-auth@kubernetescrd,%s-docs-media-rewrite@kubernetescrd" $ns $ns -}}
{{- $emailParts := splitList ":" .Values.email.host }}

image:
  repository: lasuite/impress-backend
  tag: {{ .Values.imageVersions.docsBackend | quote }}
  pullPolicy: IfNotPresent

backend:
  replicas: 1
  # Probes tuned for a constrained single node: the backend runs DB migrations on first
  # boot, so liveness gets a long initialDelay (never restart it mid-migration) + a
  # tolerant timeout. Readiness still gates Ready, so the rollout isn't slowed. Fixes a
  # flaky e2e where liveness killed the slow-starting backend (the chart's startupProbe
  # can't extend its failureThreshold, so we lengthen liveness instead).
  probes:
    liveness:
      path: /__lbheartbeat__
      initialDelaySeconds: 120
      timeoutSeconds: 5
    readiness:
      path: /__heartbeat__
      timeoutSeconds: 5
  resources:
    requests:
      cpu: "100m"
      memory: "512Mi"
    limits:
      memory: "1Gi"
  celery:
    replicas: 1
    resources:
      requests:
        cpu: "50m"
        memory: "256Mi"
      limits:
        memory: "768Mi"
  envVars:
    # --- Django core ---
    DJANGO_SETTINGS_MODULE: impress.settings
    DJANGO_CONFIGURATION: Production
    DJANGO_ALLOWED_HOSTS: {{ $host | quote }}
    DJANGO_CSRF_TRUSTED_ORIGINS: {{ printf "https://%s" $host | quote }}
    DJANGO_SECRET_KEY:
      secretKeyRef:
        name: docs-secrets
        key: DJANGO_SECRET_KEY
    DJANGO_SUPERUSER_EMAIL: {{ .Values.adminEmail | quote }}
    DJANGO_SUPERUSER_PASSWORD:
      secretKeyRef:
        name: docs-secrets
        key: DJANGO_SUPERUSER_PASSWORD
    # --- PostgreSQL (CNPG) ---
    DB_HOST: {{ $pgHost | quote }}
    DB_NAME: docs
    DB_USER: docs
    DB_PORT: "5432"
    DB_PASSWORD:
      secretKeyRef:
        name: docs-db
        key: password
    # --- Cache + Celery broker (Valkey) ---
    REDIS_URL:
      secretKeyRef:
        name: docs-secrets
        key: REDIS_URL
    DJANGO_CELERY_BROKER_URL:
      secretKeyRef:
        name: docs-secrets
        key: DJANGO_CELERY_BROKER_URL
    # --- Object storage (S3 / RustFS) ---
    AWS_S3_ENDPOINT_URL: {{ $s3Endpoint | quote }}
    AWS_S3_ACCESS_KEY_ID:
      secretKeyRef:
        name: s3-credentials
        key: AWS_S3_ACCESS_KEY_ID
    AWS_S3_SECRET_ACCESS_KEY:
      secretKeyRef:
        name: s3-credentials
        key: AWS_S3_SECRET_ACCESS_KEY
    AWS_STORAGE_BUCKET_NAME: {{ .Values.objectStorage.bucket | quote }}
    # Some S3-compatible stores (Ceph/MinIO) reject the aws-chunked streaming
    # checksum that boto3 >=1.36 sends by default ("NotImplemented" on PutObject).
    # Only add checksums when the API requires them.
    AWS_REQUEST_CHECKSUM_CALCULATION: "when_required"
    AWS_RESPONSE_CHECKSUM_VALIDATION: "when_required"
    AWS_S3_REGION_NAME: {{ $s3Region | quote }}
    STORAGES_STATICFILES_BACKEND: django.contrib.staticfiles.storage.StaticFilesStorage
    # --- OIDC (Keycloak) — external endpoints for the browser, internal for the backend ---
    OIDC_RP_CLIENT_ID: docs
    OIDC_RP_CLIENT_SECRET:
      secretKeyRef:
        name: docs-secrets
        key: OIDC_RP_CLIENT_SECRET
    OIDC_RP_SIGN_ALGO: RS256
    OIDC_RP_SCOPES: "openid email profile"
    OIDC_OP_AUTHORIZATION_ENDPOINT: {{ printf "%s/auth" $kcExternal | quote }}
    OIDC_OP_LOGOUT_ENDPOINT: {{ printf "%s/logout" $kcExternal | quote }}
    OIDC_OP_JWKS_ENDPOINT: {{ printf "%s/certs" $kcInternal | quote }}
    OIDC_OP_TOKEN_ENDPOINT: {{ printf "%s/token" $kcInternal | quote }}
    OIDC_OP_USER_ENDPOINT: {{ printf "%s/userinfo" $kcInternal | quote }}
    OIDC_VERIFY_SSL: {{ $verifySsl | quote }}
    OIDC_REDIRECT_ALLOWED_HOSTS: {{ printf "https://%s" $host | quote }}
    LOGIN_REDIRECT_URL: {{ printf "https://%s" $host | quote }}
    LOGIN_REDIRECT_URL_FAILURE: {{ printf "https://%s" $host | quote }}
    LOGOUT_REDIRECT_URL: {{ printf "https://%s" $host | quote }}
    # --- Real-time collaboration (y-provider) ---
    Y_PROVIDER_API_BASE_URL: "http://docs-y-provider:80/api/"
    # The collaboration API (reset-/get-connections) is mounted under /collaboration/api/
    # in the y-provider (dist/routes.js); only /api/convert/ lives at /api/. Pointing this
    # at /api/ makes reset_connections POST to a route the server rejects (403/"Invalid route"),
    # which surfaces as a 500 on share/link-configuration changes.
    COLLABORATION_API_URL: "http://docs-y-provider:80/collaboration/api/"
    COLLABORATION_WS_URL: {{ printf "wss://%s/collaboration/ws/" $host | quote }}
    COLLABORATION_SERVER_SECRET:
      secretKeyRef:
        name: docs-secrets
        key: COLLABORATION_SERVER_SECRET
    Y_PROVIDER_API_KEY:
      secretKeyRef:
        name: docs-secrets
        key: Y_PROVIDER_API_KEY
    # --- Transactional email (external SMTP relay; Scaleway TEM recommended) ---
    {{- if .Values.email.configured }}
    EMAIL_HOST: {{ first $emailParts | quote }}
    EMAIL_PORT: {{ last $emailParts | quote }}
    EMAIL_HOST_USER:
      secretKeyRef:
        name: email-relay
        key: EMAIL_HOST_USER
    EMAIL_HOST_PASSWORD:
      secretKeyRef:
        name: email-relay
        key: EMAIL_HOST_PASSWORD
    EMAIL_USE_TLS: "True"
    EMAIL_FROM: {{ .Values.email.from | quote }}
    {{- else }}
    # No SMTP relay set — skip sending so share invitations don't raise (the default
    # smtp backend would try localhost:25). Set OWNSUITE_MTA_RELAY_USERNAME/PASSWORD
    # to enable (Scaleway TEM recommended).
    EMAIL_BACKEND: django.core.mail.backends.dummy.EmailBackend
    {{- end }}

frontend:
  replicas: 1
  image:
    repository: lasuite/impress-frontend
    tag: {{ .Values.imageVersions.docsFrontend | quote }}
    pullPolicy: IfNotPresent
  resources:
    requests:
      cpu: "50m"
      memory: "128Mi"
    limits:
      memory: "384Mi"

yProvider:
  replicas: 1
  # Serve the y-provider on :80, not the chart default :443. Traefik (k3s) treats a
  # backend service port of 443 as an HTTPS upstream and does a TLS handshake to the
  # plain-HTTP y-provider (port 4444) -> "tls: first record does not look like a TLS
  # handshake" -> 500 on the collaboration WebSocket. Port 80 keeps Traefik on HTTP.
  service:
    port: 80
  image:
    repository: lasuite/impress-y-provider
    tag: {{ .Values.imageVersions.docsYProvider | quote }}
    pullPolicy: IfNotPresent
  resources:
    requests:
      cpu: "50m"
      memory: "128Mi"
    limits:
      memory: "384Mi"
  envVars:
    COLLABORATION_BACKEND_BASE_URL: {{ printf "https://%s" $host | quote }}
    COLLABORATION_SERVER_ORIGIN: {{ printf "https://%s" $host | quote }}
    COLLABORATION_LOGGING: "true"
    COLLABORATION_SERVER_SECRET:
      secretKeyRef:
        name: docs-secrets
        key: COLLABORATION_SERVER_SECRET
    Y_PROVIDER_API_KEY:
      secretKeyRef:
        name: docs-secrets
        key: Y_PROVIDER_API_KEY

# --- Ingress (Traefik, K3s-bundled). cert-manager issues docs-tls on the main
#     ingress; the other ingresses reuse that secret for the same host. Traefik
#     proxies websockets natively, so the collaboration routes need no special
#     annotations (single y-provider replica => no room-sticky routing needed).
ingress:
  enabled: true
  className: traefik
  host: {{ $host | quote }}
  path: /
  annotations:
    cert-manager.io/cluster-issuer: {{ .Values.tls.issuer | quote }}
  tls:
    enabled: true
    secretName: docs-tls

ingressCollaborationWS:
  enabled: true
  className: traefik
  host: {{ $host | quote }}
  path: /collaboration/ws/
  annotations: {}
  tls:
    enabled: true
    secretName: docs-tls

ingressCollaborationApi:
  enabled: true
  className: traefik
  host: {{ $host | quote }}
  path: /collaboration/api/
  annotations: {}
  tls:
    enabled: true
    secretName: docs-tls

ingressAdmin:
  enabled: true
  className: traefik
  host: {{ $host | quote }}
  path: /admin
  annotations: {}
  tls:
    enabled: true
    secretName: docs-tls

# Authenticated media serving: handled in BOTH modes by the docs-media-proxy release
# (a tiny nginx that does the media-auth subrequest + SigV4 + rewrite to the store —
# RustFS over http in in-cluster mode, the external S3 over TLS in external mode). The
# docs chart's own media Ingress here targets a portless ExternalName Service that
# Traefik cannot route, so it is always disabled in favour of the proxy.
ingressMedia:
  enabled: false
  className: traefik
  host: {{ $host | quote }}
  path: /media/
  annotations:
    traefik.ingress.kubernetes.io/router.middlewares: {{ $mediaMiddlewares | quote }}
  tls:
    enabled: true
    secretName: docs-tls

serviceMedia:
  host: {{ printf "rustfs-svc.%s.svc.cluster.local" $ns | quote }}
  port: 9000
