# Local clone of the reference implementation — kept for inspiration, NOT part of this repo.
/lasuite-platform/

# MkDocs build output
/site/

# Python virtualenv / caches
.venv/
venv/
__pycache__/
*.pyc

# Secrets and local env files (never commit). The Helmfile stack derives every
# credential from $OWNSUITE_SECRET_SEED at sync time; nothing secret is stored
# in the repo. Committed Helmfile env/values are *.gotmpl (no secrets in them).
*.secret-overrides.yaml
/helmfile/environments/secrets.yaml
.env

# Ansible — real inventory (keep only the example), retries, fetched kubeconfig
ansible/inventory/hosts.yml
*.retry
/kubeconfig

# Molecule ephemeral state
.molecule/

# pytest cache (Helmfile e2e assertions)
.pytest_cache/

# OS noise
.DS_Store
