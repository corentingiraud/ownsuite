# OwnSuite — operator configuration for the Helmfile layer (Phase 1).
#
# Copy this to `.env` (git-ignored), edit, then load it before `make sync`:
#
#   cp .env.example .env
#   $EDITOR .env
#   set -a && source .env && set +a
#
# Everything is derived from OWNSUITE_SECRET_SEED; nothing secret is committed.
# Or let `make install` (Phase 4, ADR-018) generate this file and the seed for you —
# it shows the seed once and NEVER writes it to the repo (keep it in a password
# manager). The manual flow below remains the fallback.

# REQUIRED — single seed from which every credential is derived (ADR-012).
# Generate once and keep it in a password manager: losing it means rotating all
# credentials; leaking it leaks them all.
#   openssl rand -hex 24
OWNSUITE_SECRET_SEED=

# Base domain. Each component is exposed at <name>.{domain} (e.g. auth.{domain}).
OWNSUITE_DOMAIN=assoc.example.org

# Contact address used for app admin / superuser accounts (e.g. the Docs admin).
OWNSUITE_ADMIN_EMAIL=admin@assoc.example.org

# TLS issuer (ADR-013/ADR-019): "letsencrypt-http01" (production — needs public DNS +
# port 80), "letsencrypt-staging" (Let's Encrypt staging — untrusted leaf, high rate
# limits), or "selfsigned" (local/dev/CI). `make install` drives staging→production
# automatically; set this by hand only for the manual flow. Optionally override the
# ACME directories with OWNSUITE_ACME_SERVER / OWNSUITE_ACME_STAGING_SERVER.
OWNSUITE_TLS_ISSUER=letsencrypt-http01
OWNSUITE_ACME_EMAIL=admin@assoc.example.org

# --- Applications (ADR-035: every app is OFF by default) ---------------------
# Turn each on with true. Every app is optional and off by default. Per-app knobs
# (Grist storage/org/sandbox, etc.) have defaults in the Helmfile — see the docs.
OWNSUITE_APP_DOCS=false
OWNSUITE_APP_DRIVE=false
OWNSUITE_APP_GRIST=false
OWNSUITE_APP_PROJECTS=false
OWNSUITE_APP_MESSAGES=false
OWNSUITE_APP_MEET=false

# --- Meet (only if OWNSUITE_APP_MEET=true — video conferencing, LiveKit) ------
# Meet is the only app that needs non-HTTP ports: LiveKit media on 7882/udp with a
# 7881/tcp fallback (one muxed port each — no large UDP range, no TURN). Open them
# by setting `enable_meet = true` in Terraform (security group) AND `enable_meet:
# true` in Ansible (group_vars) — same conditional-firewall pattern as the mailbox
# port 25. Recording is written to its own S3 bucket below.
OWNSUITE_MEET_S3_BUCKET=meet-recordings

# --- Mailbox (only if OWNSUITE_APP_MESSAGES=true — ADR-026) -------------------
# Outbound is relayed through a reputable EU SMTP relay (never direct from the
# VPS IP). The non-secret config is below; the relay account and DKIM key are
# SECRETS, exported in the environment before sync and NEVER written here:
#   export OWNSUITE_MTA_RELAY_USERNAME=... OWNSUITE_MTA_RELAY_PASSWORD=...
OWNSUITE_MTA_RELAY_HOST=mail.infomaniak.com:587
OWNSUITE_MTA_SPF_INCLUDE=spf.infomaniak.ch
OWNSUITE_MTA_DKIM_SELECTOR=ownsuite
OWNSUITE_MTA_DMARC_RUA=

# Object storage (ADR-003): "external" (managed EU S3, config-only) or "garage"
# (in-cluster single-node Garage, deployed + bucket bootstrapped — ADR-015).
OWNSUITE_OBJECT_STORAGE_MODE=external
OWNSUITE_S3_ENDPOINT=
OWNSUITE_S3_REGION=eu-west
# Bucket holding Docs media/attachments (created by Garage in garage mode).
OWNSUITE_S3_BUCKET=docs-media-storage

# PostgreSQL volume size.
OWNSUITE_PG_STORAGE=10Gi

# --- Backups & tested restore (ADR-006, ADR-017) -----------------------------
# Off-site by construction: the backup destination MUST survive the loss of the
# Server, so it is NEVER the in-cluster Garage you are backing up.
OWNSUITE_BACKUP_ENABLED=true
# CNPG base-backup cron (5-field); WAL archiving is continuous. Empty = on-demand.
OWNSUITE_BACKUP_SCHEDULE=0 2 * * *
# Barman recovery-window retention (PITR window). GFS-style retention is applied on
# the rclone object copy / the bucket lifecycle (see docs/operate/backups.md).
OWNSUITE_BACKUP_RETENTION=30d
# Off-site target: "external" (prod — a DIFFERENT provider/account than the primary)
# or "in-cluster" (CI/hermetic — a second in-cluster Garage). Use "external" in prod.
OWNSUITE_BACKUP_S3_TARGET=external
OWNSUITE_BACKUP_S3_ENDPOINT=
OWNSUITE_BACKUP_S3_REGION=eu-west
OWNSUITE_BACKUP_S3_BUCKET=ownsuite-backups
# Optional S3 server-side encryption for PG backups (e.g. AES256). Leave empty for
# S3-compatible stores that don't support SSE (rely on TLS + provider at-rest).
OWNSUITE_BACKUP_PG_ENCRYPTION=
#
# The off-site backup creds + the rclone encryption passphrase are derived from
# OWNSUITE_SECRET_SEED by default. For a real EXTERNAL off-site account, override the
# ids `backup-s3-access` / `backup-s3-secret` (and optionally `rclone-crypt`) with the
# account's keys via an untracked secretOverrides values file — see backups docs.

# Restore mode (set by `make restore` on a CLEAN cluster; leave false otherwise).
OWNSUITE_RESTORE=false

# SSH target of your server, used by `make tunnel` to reach the K8s API on :6443.
#   e.g. root@203.0.113.10
OWNSUITE_SERVER_SSH=
