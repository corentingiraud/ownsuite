{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    "schedule:weekly"
  ],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "description": "Group non-major Python dev/docs tooling bumps into one PR.",
      "matchManagers": ["pip_requirements"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "python tooling (non-major)"
    },
    {
      "description": "Group GitHub Actions bumps.",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    },
    {
      "description": "Group Ansible collection bumps.",
      "matchManagers": ["ansible-galaxy"],
      "groupName": "ansible collections"
    },
    {
      "description": "Group Helmfile chart + image bumps into one PR. All pins live in versions.yaml (single source of truth); the local charts' values.yaml carry no versions, so there is nothing to duplicate.",
      "matchFileNames": ["helmfile/versions/versions.yaml"],
      "groupName": "helmfile stack"
    },
    {
      "description": "Group Terraform provider/runtime bumps (the Scaleway provider lives in terraform/**/versions.tf; the built-in terraform manager detects it).",
      "matchManagers": ["terraform"],
      "groupName": "terraform providers"
    },
    {
      "description": "Group the CI Terraform/tflint binary versions (env vars caught by the CLI-tools custom manager) with the provider bumps.",
      "matchPackageNames": ["hashicorp/terraform", "terraform-linters/tflint"],
      "groupName": "terraform providers"
    }
  ],
  "customManagers": [
    {
      "description": "Track the pinned K3s release in the k3s role default (single source of truth).",
      "customType": "regex",
      "managerFilePatterns": ["/^ansible/roles/k3s/defaults/main\\.yml$/"],
      "matchStrings": ["k3s_version:\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "k3s-io/k3s",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "regex:^v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\+k3s(?<build>\\d+)$"
    },
    {
      "description": "Track pinned Helm chart versions in the Helmfile stack.",
      "customType": "regex",
      "managerFilePatterns": ["/^helmfile/versions/versions\\.yaml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) registryUrl=(?<registryUrl>\\S+) depName=(?<depName>\\S+)\\s+\\w+:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "{{{datasource}}}"
    },
    {
      "description": "Track pinned image tags in the Helmfile stack.",
      "customType": "regex",
      "managerFilePatterns": ["/^helmfile/versions/versions\\.yaml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+\\w+:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "{{{datasource}}}"
    },
    {
      "description": "Track pinned CLI tool versions (helm/helmfile/kubeconform/k3d/kubectl) in CI workflows and composite actions.",
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/(workflows|actions)/.+\\.ya?ml$/"],
      "matchStrings": [
        "[A-Z_]+_VERSION:\\s*\"?(?<currentValue>[^\"\\s]+)\"?\\s*#\\s*renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)"
      ],
      "datasourceTemplate": "{{{datasource}}}"
    }
  ]
}
