{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    "schedule:weekly"
  ],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "description": "Group non-major Python dev/docs tooling bumps into one PR.",
      "matchManagers": ["pip_requirements"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "python tooling (non-major)"
    },
    {
      "description": "Group GitHub Actions bumps.",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    },
    {
      "description": "Group Ansible collection bumps.",
      "matchManagers": ["ansible-galaxy"],
      "groupName": "ansible collections"
    },
    {
      "description": "Group Helmfile chart + image bumps into one PR. Includes the local charts' values.yaml, whose image tags are lint-only fallbacks (the real pins live in versions.yaml and are injected by the *.gotmpl values) — grouping keeps them in sync and avoids duplicate, competing PRs from the helm-values manager.",
      "matchFileNames": [
        "helmfile/versions/versions.yaml",
        "helmfile/charts/**/values.yaml"
      ],
      "groupName": "helmfile stack"
    }
  ],
  "customManagers": [
    {
      "description": "Track the pinned K3s release in group_vars.",
      "customType": "regex",
      "managerFilePatterns": ["/^ansible/group_vars/all\\.yml$/"],
      "matchStrings": ["k3s_version:\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "k3s-io/k3s",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "regex:^v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\+k3s(?<build>\\d+)$"
    },
    {
      "description": "Track pinned Helm chart versions in the Helmfile stack.",
      "customType": "regex",
      "managerFilePatterns": ["/^helmfile/versions/versions\\.yaml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) registryUrl=(?<registryUrl>\\S+) depName=(?<depName>\\S+)\\s+\\w+:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "{{{datasource}}}"
    },
    {
      "description": "Track pinned image tags in the Helmfile stack.",
      "customType": "regex",
      "managerFilePatterns": ["/^helmfile/versions/versions\\.yaml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+\\w+:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "{{{datasource}}}"
    },
    {
      "description": "Track pinned CLI tool versions (helm/helmfile/kubeconform) in CI workflows.",
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/.+\\.ya?ml$/"],
      "matchStrings": [
        "[A-Z_]+_VERSION:\\s*\"?(?<currentValue>[^\"\\s]+)\"?\\s*#\\s*renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)"
      ],
      "datasourceTemplate": "{{{datasource}}}"
    }
  ]
}
